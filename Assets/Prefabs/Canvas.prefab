--- !u!114 &853351427097508751
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 953938698937342095}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5828e2dec6733b74dadd3f11adb297c5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  testoMessaggio: {fileID: 5958195675534848765}
  immagineCornice: {fileID: 8236356940328816148}
  messaggi:
  - 'Nex

    "Maestro Orwiiin! Maestro Orwin!"'
  - "Nex\n\"Ma dov'\xE8 finito? Aveva promesso di aiutarmi con l'allenamento.\""
  - 'Nex

    "Maestro!"'
  - "Orwin\n\"Nex? Mio caro, sei arrivato fin qui! La tua connessione alle lame funziona
    gi\xE0 cos\xEC bene?\""
  - "Nex\n\"S\xEC! Non so bene cosa stia succedendo... sento un nuovo potere dentro
    di me...\""
  - "Orwin\n\"\xC8 la Frattura... Sta diventanto pi\xF9 instabile e sta portando
    i robot qui! Presto queste terre saranno invase...\""
  - "Nex\n\"Li fermer\xF2 io. Con il potere che mi hai donato, non permetter\xF2
    a nessun robot di scalfire queste terre.\""
  - "Orwin\n\"Il tuo potere \xE8 notevole ragazzo mio, e temo non far\xE0 altro che
    aumentare. Ricorda, tu sei legato alla Frattura.\""
  - 'Nex

    "Ne stanno arrivando altri! Maestro, rimanga nella casa!"'
  - "Orwin\n\"Sta attento ragazzo mio, non sappiamo come potrebbe influenzarti questa
    improvvisa instabilit\xE0 del portale...\""
  - "Nex\n\"Sono davvero in tanti... E io non mi sento pi\xF9 cos\xEC bene...\""
  - 'Orwin

    "Nex!"'
  - 'Orwin

    "Dobbiamo correre, ora!"'
  immagini:
  - {fileID: 21300000, guid: a450b8e2794cd764fbebb0261bb82f08, type: 3}
  - {fileID: 21300000, guid: 1d3f39b3b4010c440a91e441bb14fe70, type: 3}
  - {fileID: 21300000, guid: 29faa0ffaba25224cb79b606a25b1737, type: 3}
  messaggiLLM: []
